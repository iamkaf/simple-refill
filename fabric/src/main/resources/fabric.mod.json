{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": ["${mod_author}"],
  "contact": {
    "homepage": "https://github.com/iamkaf/simple-refill",
    "issues": "https://github.com/iamkaf/simple-refill/issues",
    "sources": "https://github.com/iamkaf/simple-refill"
  },
  "license": "${license}",
  "environment": "*",
  "entrypoints": {
    "main": ["com.iamkaf.simplerefill.fabric.SimpleRefillFabric"]
  },
  "mixins": [
    "${mod_id}.mixins.json",
    "${mod_id}.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*",
    "minecraft": "${fabric_version_range}",
    "java": ">=${java_version}",
    "amber": ">=${amber_version}",
    "konfig": ">=${konfig_version}"
  },
  "suggests": {
    "modmenu": ">=${mod_menu_version}"
  }
}
